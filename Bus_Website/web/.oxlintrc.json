{
  "plugins": [
    "react",
    "typescript",
    "unicorn",
    "import"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "typescript/no-explicit-any": "error",
    "react/jsx-no-useless-fragment": "warn",
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": "off"
  }
}